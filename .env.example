############
# Secrets
############

POSTGRES_PASSWORD=

############
# Backend
############

BACKEND_APP_NAME=Education Management System
BACKEND_APP_ENV=development
BACKEND_DEBUG=true
BACKEND_SECRET_KEY=your-super-secret-key-change-in-production
BACKEND_PORT=8001
BACKEND_COOKIE_DOMAIN=localhost
BACKEND_COOKIE_SECURE=false
BACKEND_COOKIE_SAMESITE=lax
SESSION_EXPIRE_MINUTES=1440
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REDIS_PASSWORD=
REDIS_PORT=6379
# Service Account API Key（留空 = 停用）
SERVICE_API_KEY=test-key-123
# Super Admin（啟動時自動建立，留空 = 跳過）
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
############
# Frontend
############

FRONTEND_URL=http://localhost:4173
FRONTEND_PORT=4173
API_URL=http://localhost:8001
VITE_API_URL=http://localhost:8001

############
# Database
############

POSTGRES_DB=postgres
POSTGRES_PORT=5432
PGADMIN_PORT=5050

############
# AWS S3
############

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=cms-user-uploads

############
# LINE Login（所有角色共用）
############

LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=http://localhost:8001/api/v1/auth/line/callback

############
# LINE Messaging（每個角色各自的 Channel Token）
############

LINE_STUDENT_MESSAGING_TOKEN=
LINE_TEACHER_MESSAGING_TOKEN=
LINE_EMPLOYEE_MESSAGING_TOKEN=

############
# Zoom OAuth 2.0（教師自用綁定）
############

ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
ZOOM_OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/zoom/oauth/callback
ZOOM_WEBHOOK_SECRET_TOKEN=
ZOOM_ENABLED=false
