# Lambda 部署設定
# 複製此檔為 .env.lambda，填入實際值
# .env.lambda 不會進 git（已加入 .gitignore）

# ── AWS 設定 ──
# deploy.sh 優先使用 --profile 參數（互動式選擇）
# 以下只在不帶 --profile 時作為 fallback
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1

# ── Lambda 環境變數 ──

# Google Drive 目標資料夾 ID
# 從 Drive 資料夾 URL 取得: https://drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=

# Google Service Account JSON（base64 編碼）
# 產生方式: cat service-account.json | base64 | tr -d '\n'
GOOGLE_SA_CREDENTIALS=

# Zoom 憑證不需要設定 — Lambda 透過 Backend internal API 取得
# Backend 管理多帳號池，Lambda 只需 meeting_id 即可
